<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- HTTPS only, trusting system certificates. The app only talks to zotero.org / api.zotero.org. -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
